# Copy this file to .env (development) or .env.production (production) and fill in real values.
# Never commit .env or .env.production to source control.

# Base URL of the backend API.
# Development: leave as /api — Vite's dev proxy forwards /api → VITE_API_TARGET
# Production:  set to the full API origin, e.g. https://api.example.com/api
VITE_API_BASE_URL=/api

# Backend origin used by the Vite dev proxy (development only, ignored in production builds).
VITE_API_TARGET=http://localhost:5000
